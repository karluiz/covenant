{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Covenant",
  "version": "0.9.9",
  "identifier": "com.karluiz.covenant",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../.."
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../.."
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Covenant",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 17 },
        "transparent": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "followsWindowActiveState"
        }
      },
      {
        "label": "notch",
        "url": "notch/index.html",
        "title": "Notch",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "focus": false,
        "visible": false,
        "width": 360,
        "height": 440
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/karluiz/covenant/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCMUU4REExRDM5RDFDMjAKUldRZ0hKM1RvWTBlK3dJR2FtZEkvZGZNa29pNVVqRUJzazdDdWtTME11RVp1eEpOWUVsb2UzWGsK"
    }
  }
}

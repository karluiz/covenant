{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Covenant",
  "version": "0.2.21",
  "identifier": "com.karluiz.covenant",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../.."
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../.."
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Covenant",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "transparent": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libssl3",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "openssl",
          "gtk3",
          "libappindicator-gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}

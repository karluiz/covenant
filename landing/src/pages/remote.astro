---
import Base from "../layouts/Base.astro";
---
<Base title="Covenant · Remote" description="Remote tab dashboard">
  <main id="rc" class="mx-auto max-w-6xl px-4 py-4 flex flex-col h-[calc(100dvh-4rem)]">
    <div class="rc-head">
      <div class="rc-title-row">
        <h1 class="rc-brand">Covenant · Remote</h1>
        <p id="rc-status" class="rc-status">not connected</p>
        <div class="rc-spacer"></div>
        <button id="rc-token-toggle" class="rc-btn rc-btn-ghost hidden">change token</button>
        <button id="rc-new-tab" class="rc-btn rc-btn-accent">+ New tab</button>
      </div>
      <p class="rc-hint">Token: in the desktop app, <span class="rc-hint-strong">Covenant → File → Copy Remote Pairing Token</span>. It expires after 30 days — copy a fresh one when this stops connecting.</p>
    </div>

    <div id="rc-token-row" class="rc-token-row">
      <input id="rc-token" type="password" placeholder="pairing token (JWT)" class="rc-token-input" />
      <button id="rc-connect" class="rc-btn rc-btn-accent rc-btn-lg">Connect</button>
    </div>

    <input id="rc-filter" class="rc-filter hidden" type="text" placeholder="filter tabs…  ⏎ jump to first waiting" autocomplete="off" spellcheck="false" />
    <p id="rc-open-error" class="rc-open-error"></p>

    <div id="rc-body" class="rc-body" data-view="list">
      <div id="rc-list" class="rc-list"></div>
      <div id="rc-detail" class="rc-detail">
        <div id="rc-detail-info"></div>
        <div id="rc-detail-mirror" class="rc-mirror hidden">
          <span class="rc-mirror-label">live mirror</span>
          <div id="rc-mirror-term" class="rc-mirror-term"></div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    /* Remote is a control surface, not a marketing page: it commits to the
       app's dark terminal world and speaks the app's semantic palette
       (docs/DESIGN.md) so a tab's state is a COLOR, not just a word. */
    #rc {
      --rc-ink: #f5f6f7;
      --rc-dim: #8b929b;
      --rc-faint: #5c626c;
      --rc-surface: #1b1d27;
      --rc-sunken: #101119;
      --rc-rule: rgb(245 246 247 / 0.11);
      --rc-rule-soft: rgb(245 246 247 / 0.06);
      --rc-accent: #7aa2f7;
      --rc-ok: #9ece6a;       /* done / synced */
      --rc-run: #7dcfff;      /* in flight */
      --rc-think: #bb9af7;    /* thinking */
      --rc-wait: #f7768e;     /* stopped, waiting on you */
      --rc-arm: #9ece6a;      /* armed */
      font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      color: var(--rc-ink);
      font-size: 14px;
    }

    .rc-head { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.75rem; }
    .rc-title-row { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; }
    .rc-brand { font-size: 1.125rem; color: var(--rc-accent); margin: 0; font-weight: 600; letter-spacing: -0.01em; }
    .rc-status { font-size: 0.8rem; color: var(--rc-faint); margin: 0; display: flex; align-items: center; gap: 0.4rem; }
    .rc-status::before { content: "○"; }
    .rc-status[data-state="online"] { color: var(--rc-ok); }
    .rc-status[data-state="online"]::before { content: "●"; }
    .rc-status[data-state="partial"] { color: var(--rc-run); }
    .rc-status[data-state="partial"]::before { content: "●"; }
    .rc-status[data-state="warn"] { color: var(--rc-wait); }
    .rc-spacer { flex: 1; }
    .rc-hint { font-size: 0.72rem; color: var(--rc-faint); margin: 0; }
    .rc-hint-strong { color: var(--rc-dim); }

    .rc-btn {
      font-family: inherit; font-size: 0.75rem; cursor: pointer;
      padding: 0.35rem 0.7rem; border: 1px solid var(--rc-rule);
      background: var(--rc-surface); color: var(--rc-ink);
      transition: background 0.12s, border-color 0.12s;
    }
    .rc-btn:hover { background: rgb(245 246 247 / 0.06); }
    .rc-btn:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: 1px; }
    .rc-btn-ghost { color: var(--rc-dim); }
    .rc-btn-accent { color: var(--rc-accent); border-color: rgb(122 162 247 / 0.4); }
    .rc-btn-accent:hover { background: rgb(122 162 247 / 0.12); }
    .rc-btn-lg { padding: 0.5rem 1rem; font-size: 0.85rem; }

    .rc-token-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
    .rc-token-input {
      flex: 1; font-family: inherit; font-size: 0.85rem;
      padding: 0.5rem 0.75rem; background: var(--rc-sunken);
      border: 1px solid var(--rc-rule); color: var(--rc-ink);
    }
    .rc-token-input:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: 1px; }

    .rc-filter {
      font-family: inherit; font-size: 0.8rem; margin-bottom: 0.5rem;
      padding: 0.4rem 0.6rem; background: var(--rc-sunken);
      border: 1px solid var(--rc-rule); color: var(--rc-ink); width: 100%;
    }
    .rc-filter:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: 1px; }
    .rc-open-error { font-size: 0.72rem; color: var(--rc-wait); margin: 0 0 0.25rem; min-height: 1rem; }

    .rc-body {
      flex: 1; min-height: 0; display: grid; gap: 0.75rem;
      grid-auto-rows: 1fr; grid-template-columns: minmax(0, 1fr);
    }
    /* minmax(0,1fr), not 1fr: the mirror's xterm keeps its full unscaled
       layout box (transform:scale shrinks pixels, not the box), so a plain
       1fr track = minmax(auto,1fr) would grow to that width and shove the
       detail pane off-screen. minmax(0,…) lets the track shrink below its
       content and clip instead. */
    @media (min-width: 768px) { .rc-body { grid-template-columns: 300px minmax(0, 1fr); } }

    /* Panes: desktop shows both; mobile shows one per data-view. Kept off the
       global .hidden helper so the desktop layout never fights an !important. */
    .rc-list { min-height: 0; overflow-y: auto; display: block; }
    .rc-detail {
      min-width: 0; min-height: 0; display: flex; flex-direction: column; padding: 0.85rem;
      border: 1px solid var(--rc-rule); background: var(--rc-sunken);
    }
    @media (max-width: 767px) {
      .rc-body[data-view="list"] .rc-detail { display: none; }
      .rc-body[data-view="detail"] .rc-list { display: none; }
    }

    /* ---- group headers + rows ---- */
    .rc-group-head {
      display: flex; align-items: baseline; gap: 0.5rem; width: 100%;
      padding: 0.5rem 0.5rem 0.25rem; margin-top: 0.4rem;
      border-top: 1px solid var(--rc-rule-soft);
      font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--rc-faint); background: none; border-left: 0; border-right: 0;
      cursor: pointer; font-family: inherit; text-align: left;
    }
    .rc-group-head:first-child { border-top: 0; margin-top: 0; }
    .rc-group-head:hover { color: var(--rc-dim); }
    .rc-group-head .rc-caret { width: 0.7rem; display: inline-block; }
    .rc-group-head .rc-count { margin-left: auto; opacity: 0.75; }

    .rc-row {
      width: 100%; text-align: left; font-family: inherit;
      display: flex; align-items: baseline; gap: 0.5rem;
      padding: 0.3rem 0.5rem; font-size: 0.82rem;
      background: none; border: 1px solid transparent; cursor: pointer;
      color: var(--rc-dim);
    }
    .rc-row:hover { background: rgb(245 246 247 / 0.04); }
    .rc-row.sel { background: rgb(122 162 247 / 0.12); border-color: rgb(122 162 247 / 0.35); }
    .rc-row:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: -2px; }
    .rc-row .rc-dot { color: var(--rc-faint); }
    .rc-row.armed .rc-dot { color: var(--rc-arm); }
    .rc-row.armed .rc-leaf { color: var(--rc-ink); }
    .rc-leaf { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rc-phase { font-size: 0.72rem; white-space: nowrap; }
    .rc-phase.tone-wait { color: var(--rc-wait); }
    .rc-phase.tone-done { color: var(--rc-ok); }
    .rc-phase.tone-run { color: var(--rc-run); }
    .rc-phase.tone-think { color: var(--rc-think); }
    .rc-phase.tone-idle { color: var(--rc-faint); }

    /* ---- detail pane ---- */
    .rc-back { display: none; }
    @media (max-width: 767px) { .rc-back { display: inline-block; } }
    .rc-detail-title { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
    .rc-detail-title .rc-t { color: var(--rc-accent); }
    .rc-detail-title .rc-t.armed { color: var(--rc-ink); }
    .rc-detail-meta { font-size: 0.72rem; color: var(--rc-faint); }
    .rc-cwd { font-size: 0.72rem; color: var(--rc-faint); word-break: break-all; }
    .rc-badge { font-size: 0.72rem; margin-top: 0.25rem; }
    .rc-badge.armed { color: var(--rc-arm); }
    .rc-badge.unarmed { color: var(--rc-faint); }

    /* quick-key row: what a stopped agent actually asks for */
    .rc-keys { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.6rem; }
    .rc-key {
      font-family: inherit; font-size: 0.76rem; cursor: pointer;
      padding: 0.2rem 0.5rem; background: var(--rc-surface);
      border: 1px solid var(--rc-rule); color: var(--rc-ink);
      transition: background 0.1s;
    }
    .rc-key:hover { background: rgb(245 246 247 / 0.08); }
    .rc-key:active { background: rgb(122 162 247 / 0.2); }
    .rc-key:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: 1px; }
    .rc-key.warn { color: var(--rc-think); }
    .rc-key.stop { color: var(--rc-wait); }

    .rc-cmd-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem; }
    .rc-cmd {
      flex: 1; min-width: 8rem; font-family: inherit; font-size: 0.82rem;
      padding: 0.35rem 0.6rem; background: var(--rc-sunken);
      border: 1px solid rgb(122 162 247 / 0.25); color: var(--rc-ink);
    }
    .rc-cmd:focus-visible { outline: 2px solid var(--rc-accent); outline-offset: 1px; }
    .rc-focus, .rc-close { font-size: 0.74rem; padding: 0.3rem 0.55rem; }
    .rc-close { color: var(--rc-wait); border-color: rgb(247 118 142 / 0.4); }
    .rc-rej { margin-top: 0.4rem; font-size: 0.72rem; color: var(--rc-wait); }
    .rc-arm-hint { margin-top: 0.5rem; font-size: 0.72rem; color: var(--rc-faint); }
    .rc-empty { font-size: 0.8rem; color: var(--rc-faint); padding: 0.5rem; }

    .rc-mirror { flex-direction: column; flex: 1; min-width: 0; min-height: 0; margin-top: 0.6rem; }
    .rc-mirror:not(.hidden) { display: flex; }
    .rc-mirror-label { font-size: 0.7rem; color: var(--rc-ok); margin-bottom: 0.3rem; }
    /* min-width:0 so the wide xterm layout box is clipped here, not allowed to
       widen the pane; the scale transform then has a bounded container to fit. */
    .rc-mirror-term { flex: 1; min-width: 0; min-height: 0; overflow: hidden; border: 1px solid var(--rc-rule); background: #000; }

    .hidden { display: none !important; }
  </style>

  <script>
    import { mountRemoteDashboard } from "../islands/RemoteDashboard";
    mountRemoteDashboard();
  </script>
</Base>

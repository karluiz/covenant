---
const shots = [
  { 
    title: "Multi-session orchestration", 
    description: "Run multiple terminal sessions simultaneously with isolated contexts.",
    image: "/images/hero/laptop1.png" 
  },
  { 
    title: "Super-agent panel", 
    description: "Monitor and control AI agents across all your sessions in real-time.",
    image: "/images/hero/laptop2.png" 
  },
  { 
    title: "Covenant Score dashboard",
    description: "Track safety metrics and compliance scores at a glance.",
    image: "/images/hero/laptop1.png"
  },
  {
    title: "Operator-attributed PRs",
    description: "Every commit and PR is attributed to the responsible operator.",
    image: "/images/hero/laptop3.png"
  },
];
---
<section class="section">
  <p class="eyebrow fade-in-up">Deep dive</p>
  <h2 class="mt-4 text-3xl md:text-5xl font-semibold tracking-tight max-w-3xl fade-in-up delay-100">
    See the orchestrator in action.
  </h2>
  <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6 md:grid-rows-[1fr_1fr]">
    <!-- Row 1: Small (1 col) + Large (2 cols) -->
    <figure class="h-full flex flex-col rounded-xl border border-mist/10 overflow-hidden bg-mist/[0.02] fade-in-up delay-200">
      <div class="flex-1 bg-gradient-to-br from-mist/5 to-transparent grid place-items-center text-mist/40 text-sm">
        <img src={shots[0].image} alt={shots[0].title} class="w-full h-full object-cover" loading="lazy" />
      </div>
      <figcaption class="px-4 py-4">
        <h3 class="text-lg font-semibold">{shots[0].title}</h3>
        <p class="mt-1 text-sm text-mist/60">{shots[0].description}</p>
      </figcaption>
    </figure>
    <figure class="h-full flex flex-col md:col-span-2 rounded-xl border border-mist/10 overflow-hidden bg-mist/[0.02] fade-in-up delay-300">
      <div class="flex-1 bg-gradient-to-br from-mist/5 to-transparent grid place-items-center text-mist/40 text-sm">
        <img src={shots[1].image} alt={shots[1].title} class="w-full h-full object-cover" loading="lazy" />
      </div>
      <figcaption class="px-4 py-4">
        <h3 class="text-lg font-semibold">{shots[1].title}</h3>
        <p class="mt-1 text-sm text-mist/60">{shots[1].description}</p>
      </figcaption>
    </figure>
    
    <!-- Row 2: Large (2 cols) + Small (1 col) -->
    <figure class="h-full flex flex-col md:col-span-2 rounded-xl border border-mist/10 overflow-hidden bg-mist/[0.02] fade-in-up delay-400">
      <div class="flex-1 bg-gradient-to-br from-mist/5 to-transparent grid place-items-center text-mist/40 text-sm">
        <img src={shots[2].image} alt={shots[2].title} class="w-full h-full object-cover" loading="lazy" />
      </div>
      <figcaption class="px-4 py-4">
        <h3 class="text-lg font-semibold">{shots[2].title}</h3>
        <p class="mt-1 text-sm text-mist/60">{shots[2].description}</p>
      </figcaption>
    </figure>
    <figure class="h-full flex flex-col rounded-xl border border-mist/10 overflow-hidden bg-mist/[0.02] fade-in-up delay-500">
      <div class="flex-1 bg-gradient-to-br from-mist/5 to-transparent grid place-items-center text-mist/40 text-sm">
        <img src={shots[3].image} alt={shots[3].title} class="w-full h-full object-cover" loading="lazy" />
      </div>
      <figcaption class="px-4 py-4">
        <h3 class="text-lg font-semibold">{shots[3].title}</h3>
        <p class="mt-1 text-sm text-mist/60">{shots[3].description}</p>
      </figcaption>
    </figure>
  </div>
</section>

---
const githubUrl = "https://github.com/karluiz/covenant";
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-ink/80 backdrop-blur-md border-b border-mist/10">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/brand/covenant-logotipo.svg" alt="Covenant" class="h-8" />
    </a>
    <div class="flex items-center gap-6">
      <a href="#install" class="text-mist/70 hover:text-mist transition text-sm">Install</a>
      <a href="/remote" class="text-mist/70 hover:text-mist transition text-sm">Remote</a>
      <a href="https://forge.covenant.uno" class="text-mist/70 hover:text-mist transition text-sm">Forge</a>
      <a href={githubUrl} class="text-mist/70 hover:text-mist transition text-sm">GitHub</a>
    </div>
  </div>
</nav>

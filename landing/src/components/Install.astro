<section id="install" class="section !pt-0 -mt-32 md:-mt-48 relative z-10 text-center">
  <p class="eyebrow fade-in-up">Install</p>
  <h2 class="mt-4 text-3xl md:text-5xl font-semibold tracking-tight fade-in-up delay-100">
    One clic, one command.
  </h2>
  <button 
    id="copy-command" 
    class="mt-8 inline-flex items-center gap-3 rounded-lg border border-mist/15 bg-mist/[0.04] px-5 py-4 font-mono text-mist fade-in-up delay-200 cursor-pointer hover:border-moss-500/40 hover:bg-mist/[0.08] transition-all relative overflow-hidden group"
  >
    <span class="text-moss-400">$</span>
    <code>brew install --cask karluiz/covenant/covenant</code>
    <svg class="w-4 h-4 text-mist/40 group-hover:text-mist/70 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
    </svg>
    <!-- Flash effect overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full flash-effect pointer-events-none"></div>
  </button>
  <p id="copy-feedback" class="mt-3 text-sm text-moss-400 opacity-0 transition-opacity duration-300">Copied to clipboard!</p>

  <div class="mt-6 flex items-center justify-center gap-3 fade-in-up delay-300">
    <span class="text-mist/30 text-sm">or</span>
  </div>
  <div class="mt-4 fade-in-up delay-300">
    <a
      id="win-download"
      href="https://github.com/karluiz/covenant/releases/latest"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 rounded-lg border border-mist/15 bg-mist/[0.04] px-5 py-4 text-mist cursor-pointer hover:border-sky-500/40 hover:bg-mist/[0.08] transition-all"
    >
      <svg class="w-5 h-5 text-sky-400" viewBox="0 0 24 24" fill="currentColor">
        <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-13.051-1.801"/>
      </svg>
      <span class="font-medium">Download for Windows</span>
      <span class="text-mist/50 text-sm">.msi</span>
    </a>
  </div>

  <div class="mt-4 flex flex-wrap items-center justify-center gap-4 fade-in-up delay-300">
    <a
      id="rpm-download"
      href="https://github.com/karluiz/covenant/releases/latest"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 rounded-lg border border-mist/15 bg-mist/[0.04] px-5 py-4 text-mist cursor-pointer hover:border-sky-500/40 hover:bg-mist/[0.08] transition-all"
    >
      <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      <span class="font-medium">Fedora</span>
      <span class="text-mist/50 text-sm">.rpm</span>
    </a>
    <a
      id="deb-download"
      href="https://github.com/karluiz/covenant/releases/latest"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 rounded-lg border border-mist/15 bg-mist/[0.04] px-5 py-4 text-mist cursor-pointer hover:border-sky-500/40 hover:bg-mist/[0.08] transition-all"
    >
      <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      <span class="font-medium">Ubuntu / Debian</span>
      <span class="text-mist/50 text-sm">.deb</span>
    </a>
    <a
      id="appimage-download"
      href="https://github.com/karluiz/covenant/releases/latest"
      target="_blank"
      rel="noopener"
      class="text-sm text-mist/50 hover:text-mist/80 underline underline-offset-4 transition-colors"
    >AppImage</a>
  </div>

  <p class="mt-5 text-sm text-mist/60 fade-in-up delay-300">macOS · Windows · Linux</p>
</section>

<style>
  @keyframes flash {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .flash-animate {
    animation: flash 0.6s ease-out;
  }
</style>

<script>
  const copyButton = document.getElementById('copy-command');
  const feedback = document.getElementById('copy-feedback');
  const flashOverlay = copyButton?.querySelector('.flash-effect');

  copyButton?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('brew install --cask karluiz/covenant/covenant');
      
      // Trigger flash animation
      flashOverlay?.classList.add('flash-animate');
      
      // Show feedback
      feedback?.classList.remove('opacity-0');
      feedback?.classList.add('opacity-100');
      
      // Reset after animation
      setTimeout(() => {
        flashOverlay?.classList.remove('flash-animate');
      }, 600);
      
      setTimeout(() => {
        feedback?.classList.remove('opacity-100');
        feedback?.classList.add('opacity-0');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });

  // Resolve the latest per-platform assets so the buttons are true one-click
  // downloads. Filenames embed the version (Covenant_<ver>_x64_en-US.msi,
  // Covenant_<ver>_amd64.deb, …), so static "latest/download/<name>" links
  // would 404 after each release — instead query the GitHub Releases API at
  // runtime. Every href already points at the releases page, so if the API is
  // rate-limited/unreachable the buttons still work (just one extra click).
  const downloads: Array<[string, string]> = [
    ['win-download', '.msi'],
    ['rpm-download', '.rpm'],
    ['deb-download', '.deb'],
    ['appimage-download', '.appimage'],
  ];
  fetch('https://api.github.com/repos/karluiz/covenant/releases/latest', {
    headers: { Accept: 'application/vnd.github+json' },
  })
    .then((r) => (r.ok ? r.json() : Promise.reject(new Error('release fetch failed'))))
    .then((release: { assets?: Array<{ name: string; browser_download_url: string }> }) => {
      for (const [id, ext] of downloads) {
        const el = document.getElementById(id) as HTMLAnchorElement | null;
        const asset = release.assets?.find((a) => a.name.toLowerCase().endsWith(ext));
        if (el && asset) el.href = asset.browser_download_url;
      }
    })
    .catch(() => {
      /* keep the releases-page fallback hrefs */
    });
</script>

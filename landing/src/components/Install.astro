<section id="install" class="section text-center">
  <p class="eyebrow fade-in-up">Install</p>
  <h2 class="mt-4 text-3xl md:text-5xl font-semibold tracking-tight fade-in-up delay-100">
    One clic, one command.
  </h2>
  <button 
    id="copy-command" 
    class="mt-8 inline-flex items-center gap-3 rounded-lg border border-mist/15 bg-mist/[0.04] px-5 py-4 font-mono text-mist fade-in-up delay-200 cursor-pointer hover:border-moss-500/40 hover:bg-mist/[0.08] transition-all relative overflow-hidden group"
  >
    <span class="text-moss-400">$</span>
    <code>brew install covenant</code>
    <svg class="w-4 h-4 text-mist/40 group-hover:text-mist/70 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
    </svg>
    <!-- Flash effect overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full flash-effect pointer-events-none"></div>
  </button>
  <p id="copy-feedback" class="mt-3 text-sm text-moss-400 opacity-0 transition-opacity duration-300">Copied to clipboard!</p>
  <p class="mt-3 text-sm text-mist/60 fade-in-up delay-300">macOS today · Windows soon · Linux community</p>
</section>

<style>
  @keyframes flash {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .flash-animate {
    animation: flash 0.6s ease-out;
  }
</style>

<script>
  const copyButton = document.getElementById('copy-command');
  const feedback = document.getElementById('copy-feedback');
  const flashOverlay = copyButton?.querySelector('.flash-effect');

  copyButton?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('brew install covenant');
      
      // Trigger flash animation
      flashOverlay?.classList.add('flash-animate');
      
      // Show feedback
      feedback?.classList.remove('opacity-0');
      feedback?.classList.add('opacity-100');
      
      // Reset after animation
      setTimeout(() => {
        flashOverlay?.classList.remove('flash-animate');
      }, 600);
      
      setTimeout(() => {
        feedback?.classList.remove('opacity-100');
        feedback?.classList.add('opacity-0');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>
